# ============================================================================
# Moto Platform — environment template
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#   cp .env.example .env
# Variables marked (Stage N) are documented ahead of time and only become
# required when that stage is built.
# ============================================================================

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# Public base URL of the app (no trailing slash). Used for absolute links,
# SEO canonical URLs, and payment redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# ----------------------------------------------------------------------------
# Local dev: `docker compose up -d` gives you postgresql://moto:moto@localhost:5432/moto
#
# Supabase (used for this project): direct connections are IPv6-only unless
# you buy the IPv4 add-on, so both URLs below point at the Supavisor "Session"
# pooler (port 5432, Project Settings -> Database -> Connection string). We're
# a long-running Node process, not serverless/edge, so Session pooler (which
# supports prepared statements) is used for both runtime and migrations — the
# Transaction pooler (port 6543) is for serverless/edge deployments only.
DATABASE_URL=postgresql://moto:moto@localhost:5432/moto?schema=public
DIRECT_URL=postgresql://moto:moto@localhost:5432/moto?schema=public

# ----------------------------------------------------------------------------
# Auth.js / NextAuth (Stage 2)
# ----------------------------------------------------------------------------
# Secret used to sign JWT sessions. Generate with: openssl rand -base64 33
AUTH_SECRET=
# Canonical URL Auth.js uses for callbacks (usually same as NEXT_PUBLIC_APP_URL).
AUTH_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Cloudinary — media storage & optimization (Stage 3)
# ----------------------------------------------------------------------------
# From your Cloudinary dashboard (Settings → API Keys).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Same cloud name, exposed to the browser for building delivery URLs.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ----------------------------------------------------------------------------
# Cron — background jobs (Stage 4: scheduled vehicle publishing)
# ----------------------------------------------------------------------------
# Shared secret Vercel Cron sends as `Authorization: Bearer <value>`.
# Optional locally so the routes stay testable without provisioning one, but
# env.ts REQUIRES this when NODE_ENV=production — otherwise the cron routes
# (expire reservations, publish scheduled vehicles, subscription dunning)
# would be reachable by anyone who finds the URL.
CRON_SECRET=

# ----------------------------------------------------------------------------
# Flutterwave — buyer deposits + dealer subscriptions (Stages 6 & 8)
# ----------------------------------------------------------------------------
# Use TEST keys (FLWPUBK_TEST-... / FLWSECK_TEST-...) until go-live.
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
# The "secret hash" you set in the Flutterwave dashboard (Settings → Webhooks).
# Incoming webhooks are rejected unless their verif-hash header matches this.
# env.ts REQUIRES this in production once FLUTTERWAVE_SECRET_KEY is set.
FLUTTERWAVE_WEBHOOK_SECRET_HASH=

# ----------------------------------------------------------------------------
# Africa's Talking — SMS receipts & alerts (Stage 6)
# ----------------------------------------------------------------------------
# Use username "sandbox" with a sandbox API key during development.
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
# Registered alphanumeric sender ID or short code (optional in sandbox).
AFRICASTALKING_SENDER_ID=

# ----------------------------------------------------------------------------
# Resend — transactional email (Stage 2)
# ----------------------------------------------------------------------------
RESEND_API_KEY=
# Verified sender, e.g. "Moto <no-reply@yourdomain.com>"
EMAIL_FROM=
